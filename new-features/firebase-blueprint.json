{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and usage statistics",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "plan": { "type": "string", "enum": ["free", "pro", "api"] },
        "daily_limit": { "type": "integer" },
        "daily_used": { "type": "integer" },
        "api_key": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "plan", "daily_limit", "daily_used", "created_at"]
    },
    "MemeTemplate": {
      "title": "Meme Template",
      "description": "Base template for meme generation",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "alternative_names": { "type": "array", "items": { "type": "string" } },
        "image_url": { "type": "string" },
        "description": { "type": "string" },
        "number_of_text_fields": { "type": "integer" },
        "text_coordinates_xy_wh": { "type": "array", "items": { "type": "array", "items": { "type": "integer" } } },
        "text_color": { "type": "string" },
        "text_stroke": { "type": "boolean" },
        "font_path": { "type": "string" }
      },
      "required": ["name", "image_url", "number_of_text_fields"]
    },
    "GeneratedMeme": {
      "title": "Generated Meme",
      "description": "A synthesized meme artifact",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "prompt": { "type": "string" },
        "template_id": { "type": "string" },
        "template_name": { "type": "string" },
        "meme_text": { "type": "array", "items": { "type": "string" } },
        "image_url": { "type": "string" },
        "share_count": { "type": "integer" },
        "like_count": { "type": "integer" },
        "view_count": { "type": "integer" },
        "is_public": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["prompt", "template_id", "meme_text", "image_url", "created_at"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "templates/{templateId}": {
      "schema": "MemeTemplate",
      "description": "Library of meme templates"
    },
    "memes/{memeId}": {
      "schema": "GeneratedMeme",
      "description": "Synthesized memes gallery"
    }
  }
}
