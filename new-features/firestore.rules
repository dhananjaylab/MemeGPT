rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives ---
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // --- Validation Helpers ---
    
    function isValidUser(data) {
      return data.email is string &&
             data.plan in ['free', 'pro', 'api'] &&
             data.daily_limit is int &&
             data.daily_used is int;
    }

    function isValidMeme(data) {
      return data.prompt is string && data.prompt.size() <= 2000 &&
             data.template_id is string &&
             data.meme_text is list &&
             data.image_url is string && data.image_url.size() <= 1000000;
    }

    // --- Collections ---

    // 1. Users
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId);
    }

    // 2. Meme Templates
    match /templates/{templateId} {
      allow read: if true;
      allow write: if false;
    }

    // 3. Generated Memes
    match /memes/{memeId} {
      allow read: if true; // Publicly readable for now
      allow create: if isValidMeme(incoming()); // Publicly creatable for now
      allow update: if incoming().diff(existing()).affectedKeys().hasOnly(['like_count', 'share_count', 'view_count', 'is_public']);
      allow delete: if false; // Block public deletions
    }
  }
}
