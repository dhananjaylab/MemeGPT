# Application
APP_NAME=MemeGPT API
APP_VERSION=2.0.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Security

ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
DATABASE_URL=postgresql+asyncpg://memegpt:password@localhost:5432/memegpt
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
AI_PROVIDER=gemini

# OpenAI (fallback after Gemini, before Anthropic)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4.1-mini

# Anthropic (fallback — Phase 2: now actually wired up as an automatic
# Gemini fallback behind a circuit breaker, see services/meme_ai.py)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=memegpt-images
R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev

# JWT Authentication
# SECURITY: in production this MUST be overridden with a long random value
# (e.g. `openssl rand -hex 32`) — app startup now refuses to boot in
# ENVIRONMENT=production if this is missing, default, or under 32 chars.
JWT_SECRET_KEY=your-super-secret-jwt-key-here
JWT_ALGORITHM=HS256
# Access tokens are short-lived by design (Phase 1: moved off localStorage).
# The frontend keeps the access token in memory only and silently calls
# POST /api/auth/refresh — backed by the httpOnly refresh cookie below —
# to mint a new one when it expires.
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_COOKIE_NAME=refresh_token

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600  # 1 hour in seconds
# Short-window burst guard applied specifically to /api/memes/generate*,
# in addition to the daily per-plan quota. Re-enabled in Phase 1 after
# being fully disabled.
GENERATION_BURST_LIMIT=5
GENERATION_BURST_WINDOW_SECONDS=60

# Stripe (for billing)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_API_PRICE_ID=price_your-api-price-id

# External APIs
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=MemeGPT/2.0

NEWS_API_KEY=your-newsapi-key

# Monitoring
# Phase 2: SENTRY_DSN is now actually wired up via sentry_sdk.init() in
# core/sentry.py — previously this was set but never consumed by any code.
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=INFO

# Content moderation (Phase 2) — gates whether a generated meme is allowed
# to be public. See services/moderation.py.
MODERATION_ENABLED=true
# Fail-OPEN by default (generation still succeeds, unreviewed, if the
# moderation provider itself is down) rather than taking down all
# generation on a moderation-provider outage. Flip once you've measured
# how often that actually happens for your traffic.
MODERATION_FAIL_CLOSED=false

# File paths
TEMPLATES_DIR=../templates
FONTS_DIR=../fonts
MEME_DATA_PATH=../meme_data.json

# ARQ Worker
ARQ_REDIS_SETTINGS=redis://localhost:6379/1
ARQ_QUEUE_NAME=meme_generation

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-API-Key,X-Requested-With,Accept,Origin,User-Agent
CORS_MAX_AGE=600

# Security
TRUSTED_HOSTS=localhost,127.0.0.1,*.vercel.app
SECURE_COOKIES=false  # Set to true in production with HTTPS
