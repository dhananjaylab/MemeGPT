# Production Environment Configuration
# MemeGPT API - Production Deployment

# ─────────────────────────────────────────────────────────────────────
# Application Configuration
# ─────────────────────────────────────────────────────────────────────
APP_NAME=MemeGPT API
APP_VERSION=2.0.0
DEBUG=false
ENVIRONMENT=production

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Frontend URL (for CORS)
FRONTEND_URL=https://memegpt.com
ALLOWED_HOSTS=memegpt.com,www.memegpt.com,api.memegpt.com

# ─────────────────────────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────────────────────────
# Use environment secrets manager in production
DATABASE_URL=postgresql+asyncpg://user:password@db-host:5432/memegpt_prod
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false
DATABASE_SSL_MODE=require

# ─────────────────────────────────────────────────────────────────────
# Redis Configuration
# ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:password@redis-host:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_SSL=true
REDIS_SSL_CERT_REQS=required

# ─────────────────────────────────────────────────────────────────────
# AI Model Configuration
# ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-prod-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

ANTHROPIC_API_KEY=sk-ant-prod-your-anthropic-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ─────────────────────────────────────────────────────────────────────
# Cloudflare R2 Storage Configuration
# ─────────────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-prod-r2-account-id
R2_ACCESS_KEY_ID=prod-r2-access-key
R2_SECRET_ACCESS_KEY=prod-r2-secret-key
R2_BUCKET_NAME=memegpt-images-prod
R2_PUBLIC_URL=https://cdn.memegpt.com

# R2 Backup Configuration
R2_BACKUP_ENABLED=true
R2_BACKUP_RETENTION_DAYS=90
R2_BACKUP_SCHEDULE_DAILY=02:00  # 2 AM UTC

# ─────────────────────────────────────────────────────────────────────
# JWT Authentication Configuration
# ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-production-jwt-secret-key-here-generate-secure-random-value
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────────────────────────────
# Rate Limiting Configuration
# ─────────────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=3600
RATE_LIMIT_STORAGE=redis

# Rate limits by tier
RATE_LIMIT_FREE_REQUESTS=10
RATE_LIMIT_PRO_REQUESTS=500
RATE_LIMIT_API_REQUESTS=1000

# ─────────────────────────────────────────────────────────────────────
# Stripe Billing Configuration
# ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PRO=price_id_pro_monthly
STRIPE_PRICE_API=price_id_api_monthly

# ─────────────────────────────────────────────────────────────────────
# Security Configuration
# ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-production-secret-key-generate-secure-random-value
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict
CSRF_COOKIE_SECURE=true
CSRF_COOKIE_HTTPONLY=true

# CORS Configuration
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-API-Key,X-Requested-With,Accept,Origin,User-Agent
CORS_MAX_AGE=600
CORS_EXPOSE_HEADERS=Content-Length,Content-Type,X-RateLimit-Limit,X-RateLimit-Remaining

# Security Headers
SECURITY_HEADERS_ENABLED=true
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff
X_XSS_PROTECTION=1; mode=block
STRICT_TRANSPORT_SECURITY=max-age=31536000; includeSubDomains
CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:

# ─────────────────────────────────────────────────────────────────────
# Monitoring and Logging
# ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus Metrics
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_METRICS_PORT=9090

# ─────────────────────────────────────────────────────────────────────
# External Services
# ─────────────────────────────────────────────────────────────────────
# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Email Service
SMTP_SERVER=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@memegpt.com

# ─────────────────────────────────────────────────────────────────────
# Performance Configuration
# ─────────────────────────────────────────────────────────────────────
# Image Optimization
IMAGE_OPTIMIZATION_ENABLED=true
IMAGE_MAX_WIDTH=2048
IMAGE_MAX_HEIGHT=2048
IMAGE_DEFAULT_QUALITY=80
IMAGE_ENABLE_WEBP=true
IMAGE_ENABLE_AVIF=true

# Caching
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_REDIS_ENABLED=true

# CDN
CDN_CACHING_ENABLED=true
CDN_CACHE_BUST_ENABLED=true

# ─────────────────────────────────────────────────────────────────────
# Background Jobs
# ─────────────────────────────────────────────────────────────────────
ARQ_REDIS_SETTINGS=redis://:password@redis-host:6379/1
ARQ_JOB_TIMEOUT=3600  # 1 hour timeout for meme generation
ARQ_RESULT_TTL=86400  # Keep results for 24 hours
ARQ_WORKER_CONCURRENCY=4

# ─────────────────────────────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────────────────────────────
FEATURE_MEME_GENERATION=true
FEATURE_TRENDING_MEMES=true
FEATURE_USER_GALLERY=true
FEATURE_STRIPE_INTEGRATION=true
FEATURE_SOCIAL_SHARING=true
FEATURE_API_KEYS=true
