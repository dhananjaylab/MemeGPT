# Staging Environment Configuration
# MemeGPT API - Staging/Pre-production Testing

# ─────────────────────────────────────────────────────────────────────
# Application Configuration
# ─────────────────────────────────────────────────────────────────────
APP_NAME=MemeGPT API
APP_VERSION=2.0.0
DEBUG=true
ENVIRONMENT=staging

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=2

# Frontend URL (for CORS)
FRONTEND_URL=https://staging.memegpt.com
ALLOWED_HOSTS=staging.memegpt.com,staging-api.memegpt.com,localhost,127.0.0.1

# ─────────────────────────────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://memegpt_staging:password@staging-db:5432/memegpt_staging
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=true
DATABASE_SSL_MODE=prefer

# ─────────────────────────────────────────────────────────────────────
# Redis Configuration
# ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://staging-redis:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_SSL=false

# ─────────────────────────────────────────────────────────────────────
# AI Model Configuration
# ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-staging-your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.8

ANTHROPIC_API_KEY=sk-ant-staging-your-anthropic-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ─────────────────────────────────────────────────────────────────────
# Cloudflare R2 Storage Configuration
# ─────────────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-staging-r2-account-id
R2_ACCESS_KEY_ID=staging-r2-access-key
R2_SECRET_ACCESS_KEY=staging-r2-secret-key
R2_BUCKET_NAME=memegpt-images-staging
R2_PUBLIC_URL=https://staging-cdn.memegpt.com

# R2 Backup Configuration
R2_BACKUP_ENABLED=true
R2_BACKUP_RETENTION_DAYS=30
R2_BACKUP_SCHEDULE_DAILY=01:00  # 1 AM UTC

# ─────────────────────────────────────────────────────────────────────
# JWT Authentication Configuration
# ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-staging-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# ─────────────────────────────────────────────────────────────────────
# Rate Limiting Configuration
# ─────────────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=5000
RATE_LIMIT_WINDOW=3600
RATE_LIMIT_STORAGE=redis

# Rate limits by tier
RATE_LIMIT_FREE_REQUESTS=100
RATE_LIMIT_PRO_REQUESTS=1000
RATE_LIMIT_API_REQUESTS=5000

# ─────────────────────────────────────────────────────────────────────
# Stripe Billing Configuration
# ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_test_webhook_secret
STRIPE_PRICE_PRO=price_test_id_pro_monthly
STRIPE_PRICE_API=price_test_id_api_monthly

# ─────────────────────────────────────────────────────────────────────
# Security Configuration
# ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-staging-secret-key-change-in-production
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SECURE=true
CSRF_COOKIE_HTTPONLY=true

# CORS Configuration
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-API-Key,X-Requested-With,Accept,Origin,User-Agent
CORS_MAX_AGE=600

# Security Headers
SECURITY_HEADERS_ENABLED=true
X_FRAME_OPTIONS=SAMEORIGIN
X_CONTENT_TYPE_OPTIONS=nosniff
X_XSS_PROTECTION=1; mode=block
STRICT_TRANSPORT_SECURITY=max-age=31536000; includeSubDomains
CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:

# ─────────────────────────────────────────────────────────────────────
# Monitoring and Logging
# ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=json
SENTRY_DSN=https://your-sentry-staging-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.5

# Prometheus Metrics
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_METRICS_PORT=9090

# ─────────────────────────────────────────────────────────────────────
# External Services
# ─────────────────────────────────────────────────────────────────────
# OAuth Providers
GOOGLE_CLIENT_ID=your-staging-google-client-id
GOOGLE_CLIENT_SECRET=your-staging-google-client-secret
GITHUB_CLIENT_ID=your-staging-github-client-id
GITHUB_CLIENT_SECRET=your-staging-github-client-secret

# Email Service
SMTP_SERVER=smtp.mailtrap.io
SMTP_PORT=465
SMTP_USERNAME=your-mailtrap-username
SMTP_PASSWORD=your-mailtrap-password
EMAIL_FROM=staging@memegpt.com

# ─────────────────────────────────────────────────────────────────────
# Performance Configuration
# ─────────────────────────────────────────────────────────────────────
# Image Optimization
IMAGE_OPTIMIZATION_ENABLED=true
IMAGE_MAX_WIDTH=2048
IMAGE_MAX_HEIGHT=2048
IMAGE_DEFAULT_QUALITY=85
IMAGE_ENABLE_WEBP=true
IMAGE_ENABLE_AVIF=false

# Caching
CACHE_ENABLED=true
CACHE_TTL_SECONDS=1800
CACHE_REDIS_ENABLED=true

# CDN
CDN_CACHING_ENABLED=true
CDN_CACHE_BUST_ENABLED=true

# ─────────────────────────────────────────────────────────────────────
# Background Jobs
# ─────────────────────────────────────────────────────────────────────
ARQ_REDIS_SETTINGS=redis://staging-redis:6379/1
ARQ_JOB_TIMEOUT=3600
ARQ_RESULT_TTL=86400
ARQ_WORKER_CONCURRENCY=2

# ─────────────────────────────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────────────────────────────
FEATURE_MEME_GENERATION=true
FEATURE_TRENDING_MEMES=true
FEATURE_USER_GALLERY=true
FEATURE_STRIPE_INTEGRATION=true
FEATURE_SOCIAL_SHARING=true
FEATURE_API_KEYS=true
